<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1e293b"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Row 1: severity badge + timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvSeverity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#ef4444"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"/>

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="2024-01-01 12:00"
            android:textColor="#64748b"
            android:textSize="12sp"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Row 2: Trigger reason -->
    <TextView
        android:id="@+id/tvReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temperature exceeded threshold"
        android:textColor="#e2e8f0"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <!-- Row 3: Resolved status + button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvResolved"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="⚠ Unresolved"
            android:textColor="#f59e0b"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnResolve"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Mark Resolved"
            android:textSize="12sp"
            android:backgroundTint="#10b981"/>
    </LinearLayout>

</LinearLayout>
